{
  "entities": {
    "user_progress": {
      "title": "User Progress",
      "description": "User learning progress, including unlocked and completed lessons.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The unique identifier of the user (or local fallback UID)"
        },
        "unlockedLessons": {
          "type": "array",
          "description": "List of unlocked lesson IDs"
        },
        "completedLessons": {
          "type": "array",
          "description": "List of completed lesson IDs"
        },
        "lastUpdated": {
          "type": "string",
          "description": "ISO 8601 string of the last update timestamp"
        }
      },
      "required": ["userId", "unlockedLessons", "completedLessons", "lastUpdated"]
    },
    "japanese_lessons": {
      "title": "Japanese Lessons",
      "description": "Static content of the Japanese course lessons.",
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "description": "Lesson ID number"
        },
        "title": {
          "type": "string",
          "description": "Title of the lesson"
        },
        "description": {
          "type": "string",
          "description": "Brief description of the lesson topic"
        },
        "level": {
          "type": "string",
          "description": "JLPT Level, e.g. N5"
        },
        "category": {
          "type": "string",
          "description": "Category or textbook mapping"
        },
        "grammar": {
          "type": "object",
          "description": "Grammar patterns, explanation, and examples"
        },
        "words": {
          "type": "array",
          "description": "List of vocabulary words in this lesson"
        },
        "categorizedVocab": {
          "type": "array",
          "description": "AI-categorized vocabulary groups"
        }
      },
      "required": ["id", "title", "description", "level", "category", "grammar", "words"]
    },
    "course_accounts": {
      "title": "Course Accounts",
      "description": "Custom registered accounts for the Japanese course.",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "The custom registered username"
        },
        "password": {
          "type": "string",
          "description": "The raw/hashed password"
        },
        "role": {
          "type": "string",
          "description": "The role of the user (e.g. admin, user)",
          "enum": ["admin", "user"]
        },
        "createdAt": {
          "type": "string",
          "description": "ISO 8601 string of when the account was registered"
        }
      },
      "required": ["username", "password", "role", "createdAt"]
    },
    "casual_vocab": {
      "title": "Casual Vocabulary",
      "description": "Casual or transient vocabulary words that do not belong to any specific lesson.",
      "type": "object",
      "properties": {
        "japanese": {
          "type": "string",
          "description": "Kanji/Hiragana/Katakana phrase"
        },
        "romaji": {
          "type": "string",
          "description": "Romaji pronunciation"
        },
        "vietnameseMeaning": {
          "type": "string",
          "description": "Vietnamese meaning"
        },
        "englishMeaning": {
          "type": "string",
          "description": "Optional English meaning"
        }
      },
      "required": ["japanese", "vietnameseMeaning"]
    },
    "lesson_drafts": {
      "title": "Lesson Drafts",
      "description": "Stores current state, steps, and full context of Lesson Builder pipelines.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique draft/pipeline identifier"
        },
        "schemaVersion": {
          "type": "integer",
          "description": "Schema version number"
        },
        "aiModel": {
          "type": "string",
          "description": "The AI model identifier used"
        },
        "promptVersion": {
          "type": "string",
          "description": "The version of prompts used"
        },
        "currentMessage": {
          "type": "string",
          "description": "Optional status or info message"
        },
        "pipelineState": {
          "type": "string",
          "description": "Status of the entire pipeline"
        },
        "currentStepId": {
          "type": "string",
          "description": "ID of the current active step"
        },
        "steps": {
          "type": "object",
          "description": "Key-value map of step IDs to step statuses"
        },
        "context": {
          "type": "object",
          "description": "Full workflow engine PipelineContext structure"
        },
        "createdById": {
          "type": "string",
          "description": "The unique user ID who created/owns this draft"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO 8601 string of draft creation"
        },
        "updatedAt": {
          "type": "string",
          "description": "ISO 8601 string of last draft update"
        },
        "archived": {
          "type": "boolean",
          "description": "Whether the draft is archived"
        }
      },
      "required": ["id", "schemaVersion", "aiModel", "promptVersion", "pipelineState", "steps", "context", "createdById", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "user_progress/{userId}": {
      "schema": "user_progress",
      "description": "Stores user lessons progression mapped by userId"
    },
    "japanese_lessons/{lessonId}": {
      "schema": "japanese_lessons",
      "description": "Stores details of individual lessons"
    },
    "course_accounts/{username}": {
      "schema": "course_accounts",
      "description": "Stores custom accounts info"
    },
    "casual_vocab/{wordId}": {
      "schema": "casual_vocab",
      "description": "Stores casual vocabulary words"
    },
    "lesson_drafts/{draftId}": {
      "schema": "lesson_drafts",
      "description": "Stores user lesson plans in progress"
    }
  }
}
